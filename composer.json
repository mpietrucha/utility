{
    "name": "mpietrucha/utility",
    "description": "The utility package.",
    "license": "MIT",
    "type": "liblary",
    "authors": [
        {
            "name": "Michał Pietrucha",
            "email": "michal.pietrucha@off-site.pl"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer/class-map-generator": "^1.1",
        "mpietrucha/disclosure": "^0.1.1",
        "mpietrucha/exception": "^0.1.1"
    },
    "require-dev": {
        "symfony/var-dumper": "^6.2"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "Mpietrucha\\Support\\": "src"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
